{
  "manifest_version": 3,
  "name": "ifin Platform Browser",
  "version": "1.0.1",
  "description": "Browser automation, diagnostics, and extension-backed control for ifin Platform",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "debugger",
    "sidePanel",
    "storage",
    "webNavigation",
    "alarms",
    "offscreen",
    "<all_urls>"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "devtools_page": "devtools.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
