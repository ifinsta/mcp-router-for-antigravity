# Router defaults
ROUTER_DEFAULT_PROVIDER=openai
ROUTER_DEFAULT_MODEL=gpt-4.1-mini
ROUTER_TIMEOUT_MS=45000
ROUTER_LOG_LEVEL=info
TOTAL_REQUEST_BUDGET_MS=60000
GLOBAL_CONCURRENCY_LIMIT=20

# Policy limits
ALLOWED_PROVIDERS=openai,glm,chutes,anthropic,azure-openai
ALLOWED_MODELS=gpt-4.1-mini,glm-4.5,Qwen/Qwen2.5-72B-Instruct,claude-3-5-sonnet-20241022,gpt-4o
MAX_INPUT_CHARS=120000
MAX_OUTPUT_TOKENS=4000
MAX_COST_USD_PER_REQUEST=2.50

# Provider credentials
OPENAI_API_KEY=
OPENAI_BASE_URL=
GLM_API_KEY=
GLM_BASE_URL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
CHUTES_API_KEY=
CHUTES_BASE_URL=https://llm.chutes.ai/v1

# Anthropic provider
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Azure OpenAI provider
# Requires resource name, deployment name, and API key
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_RESOURCE=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_BASE_URL=

# Resilience settings
MAX_ATTEMPTS_PER_REQUEST=3
RETRY_BASE_DELAY_MS=1000
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=30000
