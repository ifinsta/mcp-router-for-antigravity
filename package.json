{
  "name": "ifin-platform",
  "version": "1.1.0",
  "description": "A production-grade MCP platform that connects supported local clients and external LLM providers through one stable, resilient MCP server",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "ifin-platform": "./bin/ifin-platform.js",
    "setup-mcp": "./bin/setup-mcp.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "docs/QUICKSTART.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:ide-extension": "npm --prefix extension run build",
    "build:watch": "tsc --watch",
    "build:renderer": "cd electron/renderer && pnpm exec webpack --mode production",
    "build:electron": "echo 'Electron is now built with the main project' && exit 0",
    "build:all": "pnpm run build && pnpm run build:renderer",
    "dev": "tsc --watch",
    "dev:electron": "concurrently \"pnpm run dev\" \"pnpm run dev:renderer\"",
    "dev:renderer": "cd electron/renderer && pnpm exec webpack --mode development --watch",
    "prepare": "pnpm run build",
    "start": "node dist/src/index.js",
    "start:electron": "pnpm run build:all && node ./bin/start-electron.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:ide-extension": "npm --prefix extension run test:unit",
    "test:coverage": "c8 node --import tsx --test test/**/*.test.ts",
    "test:contract": "node --import tsx --test test/contract/**/*.test.ts",
    "test:chaos": "node --import tsx --test test/chaos/**/*.test.ts",
    "test:load": "node --import tsx --test test/load/**/*.test.ts",
    "test:windows": "node --import tsx --test test/windows/**/*.test.ts",
    "package:ide-extension": "npm --prefix extension run package",
    "rebuild:ide-extension": "npm run build:ide-extension && npm run test:ide-extension && npm run package:ide-extension",
    "clean": "node -e \"const fs=require('fs');['dist','coverage','build','installers'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}})\"",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "setup": "node bin/setup-mcp.js",
    "setup:wizard": "node electron/installer/setup-wizard.ts",
    "build:installer": "node electron/installer/build-installer.cjs",
    "package": "pnpm run build:all && pnpm run build:installer",
    "rebuild": "pnpm run clean && pnpm run package"
  },
  "keywords": [
    "mcp",
    "router",
    "qoder",
    "llm",
    "openai",
    "glm",
    "chutes"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "c8": "^9.0.0",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-packager": "^17.1.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "html-webpack-plugin": "^5.6.0",
    "prettier": "^3.1.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^17.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ifinsta/ifin-platform"
  },
  "bugs": {
    "url": "https://github.com/ifinsta/ifin-platform/issues"
  },
  "homepage": "https://github.com/ifinsta/ifin-platform"
}
