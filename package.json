{
  "name": "mcp-router-for-antigravity",
  "version": "1.0.0",
  "description": "A production-grade MCP router that allows Antigravity to use external LLMs and selected external tools through one stable, resilient MCP server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "node --import tsx --test",
    "test:coverage": "c8 node --import tsx --test",
    "test:contract": "node --import tsx --test test/contract/**/*.test.ts",
    "test:chaos": "node --import tsx --test test/chaos/**/*.test.ts",
    "test:load": "node --import tsx --test test/load/**/*.test.ts",
    "clean": "rm -rf dist coverage",
    "ci": "npm run typecheck && npm run lint && npm run test"
  },
  "keywords": [
    "mcp",
    "router",
    "antigravity",
    "llm",
    "anthropic",
    "openai",
    "glm"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "c8": "^9.0.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^17.4.1",
    "zod": "^3.22.4"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "homepage": ""
}
